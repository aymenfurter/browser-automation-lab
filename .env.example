# Target site
SLIDEFINDER_URL=https://your-target-site.example.com/

# Azure OpenAI (provisioned via `azd up`)
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4.1
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# Set to "false" to watch the browser in action (default: headless)
HEADLESS=true
